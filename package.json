{
  "name": "simforge",
  "productName": "SimForge",
  "version": "0.1.0",
  "description": "Local-first conversational Blender robotics authoring tool",
  "license": "Apache-2.0",
  "private": true,
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "package:extension": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/package-blender-extension.ps1",
    "make": "electron-forge make",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "check:secrets": "node scripts/check-secrets.mjs",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm check:secrets"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@assistant-ui/react": "0.14.27",
    "@sinclair/typebox": "^0.34.52",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/shared-types": "7.11.2",
    "@electron/fuses": "2.1.3",
    "@electron/node-gyp": "github:electron/node-gyp#06b29aafb7708acef8b3669835c8a7857ebc92d2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "43.1.1",
    "eslint": "^10.7.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
